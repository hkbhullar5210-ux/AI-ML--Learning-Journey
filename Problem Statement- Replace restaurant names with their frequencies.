        "Problem Statement- Replace restaurant names with their frequencies."
      ],
      "metadata": {
        "id": "pnLqdQAM4HBP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"Restaurant\":[\"A\",\"B\",\"A\",\"C\",\"A\",\"B\"]\n",
        "})\n",
        "\n",
        "freq = df[\"Restaurant\"].value_counts()\n",
        "\n",
        "df[\"Frequency\"] = df[\"Restaurant\"].map(freq)\n",
        "\n",
        "print(df)"
      ],
