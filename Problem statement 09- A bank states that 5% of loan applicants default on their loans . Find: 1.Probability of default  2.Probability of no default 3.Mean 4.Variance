      "source": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Problem statement 09- A bank states that 5% of loan applicants default on their loans .\n",
        "Find:\n",
        "1.Probability of default\n",
        "2.Probability of no default\n",
        "3.Mean\n",
        "4.Variance"
      ],
      "metadata": {
        "id": "n1PvymhVKKx7"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#Bernoulli Distribution- Loan Default\n",
        "p=0.05# Probability of default\n",
        "#Probabilities\n",
        "default=p\n",
        "no_default=1-p\n",
        "#Mean and variance\n",
        "mean=p\n",
        "variance=p*(1-p)\n",
        "print(\"P(Default)=\",default)\n",
        "print(\"P(No default)=\",no_default)\n",
        "print(\"Mean=\",mean)\n",
        "print(\"Variance=\",variance)\n",
        "print(\"\\n Interpretation:\")\n",
        "print(\"On average,5 out of every 100 loan applications will default.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "cRkNsgXAK2qB",
        "outputId": "eaea53de-f84a-4cac-cf92-ebff08c9e2a2"
      },
      "execution_count": 3,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "P(Default)= 0.05\n",
            "P(No default)= 0.95\n",
            "Mean= 0.05\n",
            "Variance= 0.0475\n",
            "\n",
            " Interpretation:\n",
            "On average,5 out of every 100 loan applications will default.\n"
          ]
        }
      ]
    },
