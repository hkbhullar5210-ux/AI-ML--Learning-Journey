        "<a href=\"https://colab.research.google.com/github/hkbhullar5210-ux/AI-ML--Learning-Journey/blob/main/Problem%20statement%2009-%20A%20bank%20states%20that%205%25%20of%20loan%20applicants%20default%20on%20their%20loans%20.%20Find%3A%201.Probability%20of%20default%20%202.Probability%20of%20no%20default%203.Mean%204.Variance\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
