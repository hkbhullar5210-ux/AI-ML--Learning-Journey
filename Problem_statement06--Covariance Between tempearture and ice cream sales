    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "temperature=[28,30,32,34,36,38,40]\n",
        "ice_cream_sales=[100,120,140,170,200,230,260]\n",
        "cov_matrix=np.cov(temperature,ice_cream_sales)\n",
        "print(\"Covariance matrix:\")\n",
        "print(cov_matrix[0,1])\n",
        "plt.scatter(temperature,ice_cream_sales)\n",
        "plt.title(\"temperature vs ice cream sales\")\n",
        "plt.xlabel(\"temperature(degrees celcius)\")\n",
        "plt.ylabel(\"ice cream sales\")\n",
        "plt.grid(True)\n",
        "plt.show()"
