      "source": [
        "Problem statement11-The heights of adult males in India follow a Normal Distribution with:\n",
        "-Mean--165cm\n",
        "-Standard Deviation=7cm\n",
        "Find the height ranges that contain:\n",
        "1.68% of mean\n",
        "2.95% of men\n",
        "3.99.7% of men"
      ],
      "metadata": {
        "id": "n1PvymhVKKx7"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Normal Distribution Example\n",
        "\n",
        "mean = 165\n",
        "std = 7\n",
        "\n",
        "# 68% range (μ ± 1σ)\n",
        "range_68 = (mean - std, mean + std)\n",
        "\n",
        "# 95% range (μ ± 2σ)\n",
        "range_95 = (mean - 2 * std, mean + 2 * std)\n",
        "\n",
        "# 99.7% range (μ ± 3σ)\n",
        "range_997 = (mean - 3 * std, mean + 3 * std)\n",
        "\n",
        "print(\"Mean =\", mean, \"cm\")\n",
        "print(\"Standard Deviation =\", std, \"cm\")\n",
        "\n",
        "print(\"\\n68% of men are between:\", range_68[0], \"and\", range_68[1], \"cm\")\n",
        "print(\"95% of men are between:\", range_95[0], \"and\", range_95[1], \"cm\")\n",
        "print(\"99.7% of men are between:\", range_997[0], \"and\", range_997[1], \"cm\")"
      ],
