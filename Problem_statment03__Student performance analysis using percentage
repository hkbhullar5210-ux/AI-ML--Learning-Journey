      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "data={\n",
        "    'Name':[\"Ravi\",\"Priya\",\"Aman\",\"Neha\",\"Karan\",\"Simran\",\"Arjun\",\"Pooja\"],\n",
        "    'School':[\"DPS\",\"DAV\",\"DPS\",\"KV\",\"DAV\",\"DPS\",\"KV\",\"DAV\"],\n",
        "    'Maths':[85,71,92,88,95,68,78,74],\n",
        "    'Science':[80,75,90,85,93,70,76,72],\n",
        "    'English':[78,82,88,80,90,75,79,77],\n",
        "    'Attendance':[95,88,97,92,99,85,90,87],\n",
        "    'passed':[True,True,True,True,True,True,True,True,]\n",
        "}\n",
        "df[\"Percentage\"]=(df[\"Maths\"]+df[\"Science\"]+df[\"English\"])/3\n",
        "print(df[['Name','Percentage']])\n",
        "def grade(p):\n",
        "    if p>=90:\n",
        "        return'A+'\n",
        "    elif p>=80:\n",
        "        return 'A'\n",
        "    elif p>=70:\n",
        "        return 'B'\n",
        "    elif p>=60:\n",
        "        return 'C'\n",
        "    else:\n",
        "        return 'F'\n",
        "\n",
        "df['Grade']=df['Percentage'].apply(grade)\n",
        "print(df[['Name','Percentage','Grade']])\n",
        "\n",
        "df=pd.DataFrame(data)\n",
        "print(df)"
      ],
