        "Problem Statement- Convert education level to their numeric values."
      ],
      "metadata": {
        "id": "pnLqdQAM4HBP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.preprocessing import LabelEncoder\n",
        "import pandas as pd\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"Education\":[\"Low\",\"Medium\",\"High\",\"Medium\",\"Low\"]\n",
        "})\n",
        "\n",
        "encoder = LabelEncoder()\n",
        "\n",
        "df[\"Education_Code\"] = encoder.fit_transform(df[\"Education\"])\n",
        "\n",
        "print(df)"
      ],
