      "source": [
        "Problem statement10- A class has students with an average score of 70 and a standard deviation of 10. Generate and  visualize a Normal distribution(Bell curve)."
      ],
      "metadata": {
        "id": "n1PvymhVKKx7"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.stats import norm\n",
        "#Mean and standard deviation\n",
        "mean=70\n",
        "std=10\n",
        "#Generate values\n",
        "x=np.linspace(30,110,100)\n",
        "#Normal distribution\n",
        "y=norm.pdf(x,mean,std)\n",
        "#Plot Bell Curve\n",
        "plt.plot(x,y)\n",
        "plt.title(\"Normal distribution(Bell Curve)\")\n",
        "plt.xlabel(\"Score\")\n",
        "plt.ylabel(\"Probability density\")\n",
        "plt.grid(True)\n",
        "plt.show()"
      ],
